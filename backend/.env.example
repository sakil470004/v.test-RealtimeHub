# ===========================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=development

# ===========================================
# MongoDB Configuration
# ===========================================
# What is MongoDB?
# - A NoSQL database that stores data in flexible, JSON-like documents
# - Unlike SQL databases, it doesn't require a fixed schema
# - Great for applications with evolving data structures
#
# Connection String Format:
# mongodb://[username:password@]host[:port]/database
MONGODB_URI=mongodb://localhost:27017/realtimehub

# ===========================================
# Redis Configuration
# ===========================================
# What is Redis?
# - An in-memory data structure store
# - Used as database, cache, message broker, and queue
# - Extremely fast because data is stored in RAM
# - Supports various data structures: strings, hashes, lists, sets, sorted sets
#
# Why use Redis?
# 1. Speed: In-memory storage = microsecond response times
# 2. Versatility: Multiple use cases (caching, queues, pub/sub)
# 3. Atomic operations: Thread-safe operations
# 4. TTL support: Automatic key expiration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# JWT Configuration
# ===========================================
# What is JWT (JSON Web Token)?
# - A compact, URL-safe means of representing claims between two parties
# - Structure: Header.Payload.Signature
# - Self-contained: Contains all user information needed
# - Stateless: Server doesn't need to store session data
#
# Why use JWT?
# 1. Scalability: No server-side session storage
# 2. Cross-domain: Works across different domains
# 3. Mobile-friendly: Easy to implement on mobile apps
# 4. Performance: No database lookup for each request
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE=7d

# ===========================================
# Rate Limiting Configuration
# ===========================================
# These values control how many requests a user can make
RATE_LIMIT_POSTS_PER_MINUTE=5
RATE_LIMIT_COMMENTS_PER_MINUTE=10
RATE_LIMIT_LIKES_PER_MINUTE=30
RATE_LIMIT_LOGIN_ATTEMPTS=5
